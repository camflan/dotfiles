{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "CLAUDE_CODE_DISABLE_AUTO_UPDATE": "1"
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/allow-safe-bash.py"
          },
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/validate-gh-readonly.py"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": false,
    "custom-lsps@custom-lsps": true,
    "claude.ai Gmail": false,
    "claude.ai Google Calendar": false,
    "claude.ai Slack": false
  },
  "alwaysThinkingEnabled": true,
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
