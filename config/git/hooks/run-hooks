#!/usr/bin/env bash
# Hook dispatcher — all hook names symlink here.
# Runs <hook>.d/*.sh (global), then .git/hooks/<hook> (repo-local).
set -euo pipefail

hook="$(basename "$0")"
dir="$(cd "$(dirname "$0")" && pwd)"
stdin="$(cat)"
rc=0

run() { [[ -x "$1" ]] && { echo "$stdin" | "$1" "${@:2}" || rc=$?; }; }

for f in "$dir/$hook.d"/*.sh; do [[ -e "$f" ]] && run "$f" "$@"; done

git_dir="$(git rev-parse --git-dir 2>/dev/null)" || true
[[ -n "$git_dir" && -x "$git_dir/hooks/$hook" ]] && run "$git_dir/hooks/$hook" "$@"

exit "$rc"
